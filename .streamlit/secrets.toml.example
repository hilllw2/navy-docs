# .streamlit/secrets.toml — LOCAL DEV ONLY (never commit this file)
# Copy this to .streamlit/secrets.toml and fill in your values for local dev.
# On Streamlit Cloud, set these in the App Settings → Secrets dashboard instead.

GEMINI_API_KEY = "your-gemini-api-key"
GEMINI_TEXT_MODEL = "gemini-2.5-flash"
GEMINI_EMBED_MODEL = "gemini-embedding-2-preview"
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_ANON_KEY = "your-supabase-anon-key"
